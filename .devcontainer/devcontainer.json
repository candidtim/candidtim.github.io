{
  "name": "Jekyll Blog",
  "image": "mcr.microsoft.com/devcontainers/ruby:3.3",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "waitFor": "onCreateCommand",
  "onCreateCommand": "gem install jekyll bundler && bundle install --quiet",
  "postCreateCommand": "jekyll build",
  "appPort": ["4000:4000"],
  "customizations": {
    "vscode": {
      "extensions": [
        "eamodio.gitlens",
        "streetsidesoftware.code-spell-checker",
        "yzhang.markdown-all-in-one"
      ]
    }
  }
}
